# PostgreSQL connection string (Replit's built-in Database pane provides one,
# or use any hosted Postgres provider).
DATABASE_URL=postgres://user:password@host:5432/dbname

# Secret bearer token that gates all admin (write) API routes and the
# /admin panel login. Pick any long random string.
# (See server/middlewares/requireAdmin.ts for how this is enforced.)
ADMIN_TOKEN=change-me-to-a-long-random-string

# Cloudflare Turnstile (bot protection on public lead forms).
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=

# Resend (transactional email for lead notifications/confirmations).
# https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Midcentury ADU <onboarding@resend.dev>
LEAD_NOTIFICATION_TO=you@example.com

# Public base URL of the deployed admin (used to build links inside emails).
ADMIN_BASE_URL=https://your-app.example.com

# Object storage (Replit App Storage / GCS-compatible). Only needed if you
# use the image/file upload features in the admin.
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
